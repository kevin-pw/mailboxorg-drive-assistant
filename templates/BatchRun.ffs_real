<?xml version="1.0" encoding="utf-8"?>
<FreeFileSync XmlType="REAL" XmlFormat="2">
    <Directories>
        <Item>__LOCAL_DIR__</Item>
        <Item>__MOUNT_POINT__/__DISPLAY_NAME__</Item>
    </Directories>
    <Delay>__DELAY_SECONDS__</Delay>
    <Commandline>xvfb-run -a __FREEFILESYNC_INSTALL_DIR__/FreeFileSync __FREEFILESYNC_INSTALL_DIR__/BatchRun.ffs_batch</Commandline>
</FreeFileSync>